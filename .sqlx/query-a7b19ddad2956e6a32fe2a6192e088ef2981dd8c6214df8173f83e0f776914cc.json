{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            ds.drug_id,\n            d.name,\n            d.category,\n            ds.unit,\n            ds.quantity_on_hand,\n            ds.reorder_threshold,\n            (ds.quantity_on_hand <= ds.reorder_threshold) AS \"is_low!\"\n        FROM drug_stock ds\n        JOIN drugs d ON d.id = ds.drug_id\n        WHERE d.is_active = TRUE\n        ORDER BY d.name ASC\n        ",
