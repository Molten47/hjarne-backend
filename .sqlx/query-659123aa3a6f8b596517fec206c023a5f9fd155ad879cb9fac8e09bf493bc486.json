  "query": "\n        UPDATE appointments\n        SET status = $1,\n            notes = COALESCE($2, notes),\n            updated_at = NOW()\n        WHERE id = $3\n      RETURNING id, patient_id, physician_id, department,\n                  appointment_type, status, scheduled_at,\n                  duration_minutes, reason, channel, daily_room_url, created_at\n        ",
