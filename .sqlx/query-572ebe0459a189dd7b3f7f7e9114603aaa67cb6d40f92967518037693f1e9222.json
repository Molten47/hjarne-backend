  "query": "\n            SELECT id, mrn, first_name, last_name, date_of_birth,\n                   gender, blood_group, portal_active\n            FROM patients\n            WHERE ($1::uuid IS NULL OR id > $1)\n            ORDER BY id\n            LIMIT $2\n            ",
