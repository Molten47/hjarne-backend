{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, event_type, payload, status, created_at, read_at\n        FROM notifications\n        WHERE recipient_id = $1\n          AND status IN ('pending', 'delivered', 'read')\n        ORDER BY created_at DESC\n        LIMIT 30\n        ",
