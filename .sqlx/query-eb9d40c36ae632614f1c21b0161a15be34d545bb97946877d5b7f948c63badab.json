{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            pm.id,\n            pm.staff_id,\n            CONCAT(s.first_name, ' ', s.last_name) AS \"staff_name!\",\n            pm.body,\n            pm.sender_type,\n            pm.sent_at,\n            pm.read_at\n        FROM portal_messages pm\n        JOIN staff s ON s.id = pm.staff_id\n        WHERE pm.patient_id = $1\n        ORDER BY pm.sent_at ASC  \n        ",
