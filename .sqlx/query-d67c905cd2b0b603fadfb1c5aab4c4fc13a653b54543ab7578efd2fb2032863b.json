  "query": "\n        SELECT id, case_file_id, prescribed_by, status,\n               prescribed_at, physician_approved, ai_confidence, ai_recommendation\n        FROM prescriptions\n        WHERE status = 'approved'\n          AND physician_approved = TRUE\n        ORDER BY prescribed_at ASC\n        LIMIT 50\n        ",
