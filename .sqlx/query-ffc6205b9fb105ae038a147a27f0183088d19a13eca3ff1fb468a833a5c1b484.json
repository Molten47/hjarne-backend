{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT id, mrn, first_name, last_name, date_of_birth,\n                       gender, blood_group, portal_active\n                FROM patients\n                WHERE LOWER(last_name)  LIKE $1\n                   OR LOWER(first_name) LIKE $1\n                   OR mrn ILIKE $1\n                ORDER BY last_name, first_name\n                LIMIT $2\n                ",
