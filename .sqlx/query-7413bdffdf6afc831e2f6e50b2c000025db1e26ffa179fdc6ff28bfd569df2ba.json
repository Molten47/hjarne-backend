{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT ds.quantity_on_hand, ds.reorder_threshold, d.name AS drug_name\n            FROM drug_stock ds\n            JOIN drugs d ON d.id = ds.drug_id\n            WHERE ds.drug_id = $1\n              AND ds.quantity_on_hand <= ds.reorder_threshold\n            ",
